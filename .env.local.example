# NextAuth
NEXTAUTH_URL=https://ekke-tracker.vercel.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (Google Cloud Console → Identifiants → Client OAuth)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# Service Account (déjà configuré dans Vercel)
# JSON complet du compte de service Google
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Email du compte de service (pour que l'utilisateur puisse partager son sheet)
SERVICE_ACCOUNT_EMAIL=ekke-tracker@your-project.iam.gserviceaccount.com

# ID du Google Sheet de tracking central (propriété du compte de service)
# Ce sheet stocke tous les événements d'ouverture et de clic
TRACKER_SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique de l'app (pour les pixels de tracking dans les mails)
NEXT_PUBLIC_APP_URL=https://ekke-tracker.vercel.app
